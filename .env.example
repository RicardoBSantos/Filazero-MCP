# Filazero API base URL
# Default: https://api.staging.filazero.net
FILAZERO_API_URL=https://api.staging.filazero.net

# Origin header sent with API requests
# Default: https://app.filazero.net
FILAZERO_APP_ORIGIN=https://app.filazero.net

# Companies cache TTL in seconds
# Default: 300
CACHE_TTL_COMPANIES=300

# Rate limit: max API requests per minute
# Default: 30
RATE_LIMIT_RPM=30

# Node environment (development | production)
NODE_ENV=production

# Nginx reverse proxy HTTP port
# Default: 8080
NGINX_HTTP_PORT=8080
